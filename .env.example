# 1. Điền chuẩn mã API Key của Gemini (Bắt đầu bằng AIzaSy)
OPENAI_API_KEY=AIzaSy...Điền_Key_Gemini_Của_Bạn_Vào_Đây...

# 2. Ép hệ thống trỏ sang máy chủ tương thích OpenAI của Google (QUAN TRỌNG)
OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai

# 3. Chỉ định mô hình Gemini 1.5 Flash
VNGR_LLM_MODEL=gemini-1.5-flash

# 4. Các thông số mặc định của hệ thống giữ nguyên
VNGR_ARTIFACTS_DIR=artifacts
VNGR_API_URL=http://localhost:8000

